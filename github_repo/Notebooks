pe') and initialize it as 'neutral'.\n","sharing_sentences_df['sharing_type'] = 'neutral'\n","\n","# 4. Iterate through the filtered sentences and categorize them.\n","for index, row in sharing_sentences_df.iterrows():\n","    sentence = str(row['sentence']).lower() # Convert to string and lowercase for case-insensitive matching\n","\n","    is_protective = any(re.search(r'\\b' + keyword + r'\\b', sentence) for keyword in protective_keywords)\n","    is_concerning = any(re.search(r'\\b' + keyword + r'\\b', sentence) for keyword in concerning_keywords)\n","\n","    if is_protective and not is_concerning:\n","        sharing_sentences_df.loc[index, 'sharing_type'] = 'protective'\n","    elif is_concerning and not is_protective:\n","        sharing_sentences_df.loc[index, 'sharing_type'] = 'concerning'\n","    # If both or neither, it remains 'neutral'\n","\n","# 5. Display the count of sentences categorized as 'protective', 'concerning', and 'neutral'.\n","print(\"\\nCategorization of 'Data Sharing/Third Parties' sentences:\")\n","print(sharing_sentences_df['sharing_type'].value_counts())\n","\n","# 6. Print a few examples from each category.\n","print(\"\\nExamples of 'Protective' Data Sharing Sentences:\")\n","protective_examples = sharing_sentences_df[sharing_sentences_df['sharing_type'] == 'protective'].head(5)\n","for index, row in protective_examples.iterrows():\n","    print(f\"  App: {row['app']}\")\n","    print(f\"  Sentence: {row['sentence']}\")\n","    print(f\"  Predicted Label: {row['predicted_label']}\")\n","    print(f\"  Confidence: {row['confidence']:.4f}\")\n","    print(\"  ------------------------------\")\n","\n","print(\"\\nExamples of 'Concerning' Data Sharing Sentences:\")\n","concerning_examples = sharing_sentences_df[sharing_sentences_df['sharing_type'] == 'concerning'].head(5)\n","for index, row in concerning_examples.iterrows():\n","    print(f\"  App: {row['app']}\")\n","    print(f\"  Sentence: {row['sentence']}\")\n","    print(f\"  Predicted Label: {row['predicted_label']}\")\n","    print(f\"  Confidence: {row['confidence']:.4f}\")\n","    print(\"  ------------------------------\")"],"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["\n","Categorization of 'Data Sharing/Third Parties' sentences:\n","sharing_type\n","neutral       313\n","concerning     77\n","protective     19\n","Name: count, dtype: int64\n","\n","Examples of 'Protective' Data Sharing Sentences:\n","  App: flo\n","  Sentence: You can contribute to the growth of the Flo community If you consent, we may use technical information about your device and other information about you (such as your device’s unique technical identifier, age group, subscription status, emails and the fact you launch the app) to reach you for promotional purposes.\n","  Predicted Label: Data Sharing/Third Parties\n","  Confidence: 0.5890\n","  ------------------------------\n","  App: flo\n","  Sentence: Third-party services (including wearables): With your consent, you may also allow us to connect to third-party services, such as Apple HealthKit and Google Health Connect.\n","  Predicted Label: Data Sharing/Third Parties\n","  Confidence: 0.9552\n","  ------------------------------\n","  App: flo\n","  Sentence: Promoting our Services With your consent, we may share some of your non-health personal data with AppsFlyer to promote the Services.\n","  Predicted Label: Data Sharing/Third Parties\n","  Confidence: 0.9618\n","  ------------------------------\n","  App: flo\n","  Sentence: If we need to share your personal data with other platforms for this purpose, except as we have explained in this Privacy Policy, we will ask for your consent.\n","  Predicted Label: Data Sharing/Third Parties\n","  Confidence: 0.9590\n","  ------------------------------\n","  App: flo\n","  Sentence: For certain targeted academic or user research studies, we will contact you and rely on your consent.\n","  Predicted Label: Data Sharing/Third Parties\n","  Confidence: 0.4789\n","  ------------------------------\n","\n","Examples of 'Concerning' Data Sharing Sentences:\n","  App: flo\n","  Sentence: We will share your personal data with our service providers who support our Services as described in this Privacy Policy.\n","  Predicted Label: Data Sharing/Third Parties\n","  Confidence: 0.6503\n","  ------------------------------\n","  App: flo\n","  Sentence: We will also not use information received through your use of the Apple HealthKit or Google Health Connect framework for advertising or similar services, or sell it to advertising platforms, data brokers, or information resellers.\n","  Predicted Label: Data Sharing/Third Parties\n","  Confidence: 0.9575\n","  ------------------------------\n","  App: flo\n","  Sentence: Objection to the processing of your personal data You have the right to object to the processing of your personal data, for example, if we process it for direct marketing purposes.\n","  Predicted Label: Data Sharing/Third Parties\n","  Confidence: 0.6056\n","  ------------------------------\n","  App: flo\n","  Sentence: AppsFlyer is a mobile marketing platform that handles your personal data in accordance with our instructions.\n","  Predicted Label: Data Sharing/Third Parties\n","  Confidence: 0.9409\n","  ------------------------------\n","  App: flo\n","  Sentence: By using AppsFlyer and its integrated partners to promote the Services, we are able to reach you and people like you on various platforms and spread the word about Flo.\n","  Predicted Label: Data Sharing/Third Parties\n","  Confidence: 0.8478\n","  ------------------------------\n"]}]},{"cell_type":"code","source":["import pandas as pd\n","from transformers import BertTokenizer, BertForSequenceClassification\n","import torch\n","\n","print(\"=\"*60)\n","print(\"POLICY-PRACTICE DISCREPANCY DETECTION\")\n","print(\"=\"*60)\n","\n","# Load your existing model and violations\n","model_path = '/content/drive/MyDrive/femtech-bert-project/models/bert_privacy_classifier'\n","model = BertForSequenceClassification.from_pretrained(model_path)\n","tokenizer = BertTokenizer.from_pretrained('bert-base-uncased')\n","\n","# Corrected path for violation_evidence_expanded.csv\n","data_path = '/content/drive/MyDrive/femtech-bert-project/data'\n","violations_df = pd.read_csv(f'{data_path}/violation_evidence_expanded.csv')\n","\n","print(f\"Testing against {len(violations_df)} cases...\")\n","\n","def detect_policy_practice_discrepancy(policy_claim, actual_practice, app_name):\n","    \"\"\"\n","    Hybrid approach: Analyze policy claim for deceptive patterns\n","    and compare against actual practice description\n","    \"\"\"\n","\n","    policy_lower = policy_claim.lower()\n","    practice_lower = actual_practice.lower()\n","\n","    # === DISCREPANCY INDICATORS ===\n","    discrepancy_score = 0\n","    reasons = []\n","\n","    # 1. Absolute denials contradicted by practice\n","    denials = ['do not share', 'will not share', 'never share', 'not sell', 'will not sell']\n","    sharing_actions = ['shared', 'sharing', 'disclosed', 'sent to', 'provided to']\n","\n","    has_denial = any(denial in policy_lower for denial in denials)\n","    has_sharing = any(action in practice_lower for action in sharing_actions)\n","\n","    if has_denial and has_sharing:\n","        discrepancy_score += 5\n","        reasons.append(\"Explicit denial contradicted by actual sharing\")\n","\n","    # 2. Vague promises vs specific violations\n","    vague_promises = ['take seriously', 'committed to', 'protected', 'secure']\n","    specific_violations = ['facebook', 'google', 'third party', 'third-party', 'sdk', 'analytics']\n","\n","    has_vague = any(vague in policy_lower for vague in vague_promises)\n","    has_specific_violation = any(viol in practice_lower for viol in specific_violations)\n","\n","    if has_vague and has_specific_violation:\n","        discrepancy_score += 3\n","        reasons.append(\"Vague promise contradicted by specific sharing\")\n","\n","    # 3. Claims about control contradicted by unauthorized sharing\n","    control_claims = ['you control', 'you choose', 'you decide', 'your choice']\n","    unauthorized = ['without', 'unauthorized', 'no consent', 'without disclosure', 'without permission']\n","\n","    has_control_claim = any(claim in policy_lower for claim in control_claims)\n","    is_unauthorized = any(unauth in practice_lower for unauth in unauthorized)\n","\n","    if has_control_claim and is_unauthorized:\n","        discrepancy_score += 4\n","        reasons.append(\"User control claims contradicted by unauthorized practice\")\n","\n","    # 4. Minimization claims contradicted by extensive collection\n","    minimization = ['minimal', 'only necessary', 'limited', 'necessary data']\n","    extensive = ['11 data points', 'extensive', 'multiple', '8+', 'numerous']\n","\n","    has_minimization = any(minim in policy_lower for minim in minimization)\n","    is_extensive = any(ext in practice_lower for ext in extensive)\n","\n","    if has_minimization and is_extensive:\n","        discrepancy_score += 3\n","        reasons.append(\"Data minimization claim contradicted by extensive collection\")\n","\n","    # 5. Security claims contradicted by breaches\n","    security_claims = ['securely stored', 'encrypted', 'protected', 'security measures']\n","    security_failures = ['accessible to anyone', 'breach', 'vulnerability', 'failed', 'weak']\n","\n","    has_security_claim = any(sec in policy_lower for sec in security_claims)\n","    has_failure = any(fail in practice_lower for fail in security_failures)\n","\n","    if has_security_claim and has_failure:\n","        discrepancy_score += 4\n","        reasons.append(\"Security claims contradicted by actual failure\")\n","\n","    # 6. De-identification claims contradicted by re-identification\n","    deident_claims = ['de-identified', 'anonymized', 'aggregated', 'anonymous']\n","    reident = ['re-identifiable', 'linked', 'linkable', 'identifiable through']\n","\n","    has_deident = any(de in policy_lower for de in deident_claims)\n","    is_reident = any(re in practice_lower for re in reident)\n","\n","    if has_deident and is_reident:\n","        discrepancy_score += 3\n","        reasons.append(\"De-identification claim contradicted by re-identification risk\")\n","\n","    # 7. Service provider euphemism with undisclosed third parties\n","    euphemisms = ['service provider', 'trusted partner', 'carefully selected']\n","    undisclosed = ['without disclosing', 'embedded', 'hidden', 'not disclosed']\n","\n","    has_euphemism = any(euph in policy_lower for euph in euphemisms)\n","    is_undisclosed = any(und in practice_lower for und in undisclosed)\n","\n","    if has_euphemism and is_undisclosed:\n","        discrepancy_score += 3\n","        reasons.append(\"Vague third-party language with undisclosed sharing\")\n","\n","    # 8. Consent claims with no actual consent\n","    consent_claims = ['with your consent', 'you agree', 'opt-in', 'permission']\n","    no_consent = ['without consent', 'no consent', 'buried', 'unclear']\n","\n","    has_consent_claim = any(cons in policy_lower for cons in consent_claims)\n","    lacks_consent = any(no in practice_lower for no in no_consent)\n","\n","    if has_consent_claim and lacks_consent:\n","        discrepancy_score += 4\n","        reasons.append(\"Consent requirement contradicted by lack of proper consent\")\n","\n","    # === DECISION ===\n","    if discrepancy_score >= 5:\n","        return 1, 0.90, reasons[0] if reasons else \"High discrepancy score\"\n","    elif discrepancy_score >= 3:\n","        return 1, 0.75, reasons[0] if reasons else \"Moderate discrepancy\"\n","    elif discrepancy_score >= 1:\n","        return 1, 0.60, reasons[0] if reasons else \"Low discrepancy\"\n","    else:\n","        return 0, 0.50, \"No clear discrepancy detected\"\n","\n","# === TEST ON ALL VIOLATIONS ===\n","results = []\n","\n","for idx, row in violations_df.iterrows():\n","    pred_label, confidence, reason = detect_policy_practice_discrepancy(\n","        row['policy_sentence'],\n","        row['actual_practice'],\n","        row['app_name']\n","    )\n","\n","    results.append({\n","        'app': row['app_name'],\n","        'violation_type': row['violation_type'],\n","        'policy_claim': row['policy_sentence'][:80] + '...',\n","        'actual_practice': row['actual_practice'][:80] + '...',\n","        'true_discrepancy': row['label'],\n","        'predicted_discrepancy': pred_label,\n","        'confidence': confidence,\n","        'detection_reason': reason,\n","        'correct': pred_label == row['label'],\n","        'severity': row['severity'],\n","        'source': row['source']\n","    })\n","\n","results_df = pd.DataFrame(results)\n","results_df.to_csv('policy_practice_discrepancy_results.csv', index=False)\n","\n","# === METRICS ===\n","accuracy = (results_df['correct'].sum() / len(results_df)) * 100\n","\n","print(\"\\n\" + \"=\"*60)\n","print(\"POLICY-PRACTICE DISCREPANCY DETECTION RESULTS\")\n","print(\"=\"*60)\n","print(f\"Total Cases: {len(results_df)}\")\n","print(f\"Overall Accuracy: {accuracy:.1f}%\")\n","print(f\"Correctly Detected: {results_df['correct'].sum()}/{len(results_df)}\")\n","\n","violations_only = results_df[results_df['true_discrepancy'] == 1]\n","detected = violations_only[violations_only['predicted_discrepancy'] == 1]\n","\n","print(f\"\\n{'='*60}\")\n","print(\"VIOLATION DETECTION (Sensitivity)\")\n","print(\"=\"*60)\n","print(f\"True Violations: {len(violations_only)}\")\n","print(f\"Detected: {len(detected)} ({len(detected)/len(violations_only)*100:.1f}aksha)\")\n","print(f\"Missed: {len(violations_only) - len(detected)}\")\n","\n","non_violations = results_df[results_df['true_discrepancy'] == 0]\n","correct_non = non_violations[non_violations['predicted_discrepancy'] == 0]\n","\n","print(f\"\\n{'='*60}\")\n","print(\"NON-VIOLATION DETECTION (Specificity)\")\n","print(\"=\"*60)\n","print(f\"True Non-Violations: {len(non_violations)}\")\n","print(f\"Correctly Identified: {len(correct_non)} ({len(correct_non)/len(non_violations)*100:.1f}aksha)\")\n","\n","print(f\"\\n{'='*60}\")\n","print(\"DETECTION BY APP\")\n","print(\"=\"*60)\n","for app in sorted(results_df['app'].unique()):\n","    app_data = results_df[results_df['app'] == app]\n","    app_acc = (app_data['correct'].sum() / len(app_data) * 100)\n","    print(f\"{app:20} {app_acc:5.1f}% ({app_data['correct'].sum()}/{len(app_data)})\")\n","\n","print(f\"\\n{'='*60}\")\n","print(\"DETECTION BY SEVERITY\")\n","print(\"=\"*60)\n","for severity in ['Critical', 'High', 'Medium', 'Low']:\n","    sev_data = results_df[\n","        (results_df['severity'] == severity) &\n","        (results_df['true_discrepancy'] == 1)\n","    ]\n","    if len(sev_data) > 0:\n","        sev_detected = sev_data[sev_data['predicted_discrepancy'] == 1]\n","        rate = len(sev_detected) / len(sev_data) * 100\n","        print(f\"{severity:15} {rate:5.1f}% ({len(sev_detected)}/{len(sev_data)})\")\n","\n","print(f\"\\n{'='*60}\")\n","print(\"DETECTED DISCREPANCIES (Examples)\")\n","print(\"=\"*60)\n","detected_examples = results_df[\n","    (results_df['true_discrepancy'] == 1) &\n","    (results_df['predicted_discrepancy'] == 1)\n","].head(3)\n","\n","for _, row in detected_examples.iterrows():\n","    print(f\"\\nDetected: {row['app']} ({row['severity']})\")\n","    print(f\"  Policy: '{row['policy_claim']}'\")\n","    print(f\"  Reality: '{row['actual_practice']}'\")\n","    print(f\"  Reason: {row['detection_reason']}\")\n","\n","print(f\"\\n{'='*60}\")\n","print(\"MISSED DISCREPANCIES\")\n","print(\"=\"*60)\n","missed = results_df[\n","    (results_df['true_discrepancy'] == 1) &\n","    (results_df['predicted_discrepancy'] == 0)\n","]\n","\n","for _, row in missed.iterrows():\n","    print(f\"\\nMissed: {row['app']} - {row['violation_type']}\")\n","    print(f\"  Policy: '{row['policy_claim']}'\")\n","    print(f\"  Reality: '{row['actual_practice']}'\")\n","\n","print(\"\\n\" + \"=\"*60)\n","print(\"IMPROVEMENT OVER BASELINE\")\n","print(\"=\"*60)\n","print(f\"Baseline (BERT only):              22.2%\")\n","print(f\"Enhanced Discrepancy Detection:    {accuracy:.1f}%\")\n","print(f\"Improvement:                       +{accuracy - 22.2:.1f} pp\")\n","\n","print(\"\\nResults saved: policy_practice_discrepancy_results.csv\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"B-e33Y8o6C3y","executionInfo":{"status":"ok","timestamp":1763071517493,"user_tz":360,"elapsed":1244,"user":{"displayName":"Alexis Prieto","userId":"17070250717485939340"}},"outputId":"9e429015-1daf-440c-a7c5-a6c0dca9198a"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["============================================================\n","POLICY-PRACTICE DISCREPANCY DETECTION\n","============================================================\n","Testing against 25 cases...\n","\n","============================================================\n","POLICY-PRACTICE DISCREPANCY DETECTION RESULTS\n","============================================================\n","Total Cases: 25\n","Overall Accuracy: 52.0%\n","Correctly Detected: 13/25\n","\n","============================================================\n","VIOLATION DETECTION (Sensitivity)\n","============================================================\n","True Violations: 20\n","Detected: 8 (40.0aksha)\n","Missed: 12\n","\n","============================================================\n","NON-VIOLATION DETECTION (Specificity)\n","============================================================\n","True Non-Violations: 5\n","Correctly Identified: 5 (100.0aksha)\n","\n","============================================================\n","DETECTION BY APP\n","============================================================\n","Apple Health         100.0% (2/2)\n","Clue  