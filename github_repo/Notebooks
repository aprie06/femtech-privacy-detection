n","sns.barplot(\n","    x='percentage',\n","    y='predicted_label',\n","    data=category_dist_df,\n","    palette='magma'\n",")\n","plt.title('Distribution of Privacy Categories Across All Apps')\n","plt.xlabel('Percentage of Sentences (%)')\n","plt.ylabel('Privacy Category')\n","\n","# Add exact percentage values on the bars\n","for index, row in category_dist_df.iterrows():\n","    plt.text(row['percentage'] + 0.5, index, f\"{row['percentage']:.1f}%\", color='black', ha=\"left\", va=\"center\")\n","\n","plt.xlim(0, category_dist_df['percentage'].max() * 1.1) # Adjust x-axis limit for text\n","plt.tight_layout()\n","plt.show()"],"execution_count":null,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 1200x700 with 1 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"code","metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"0a62b357","executionInfo":{"status":"ok","timestamp":1763071405563,"user_tz":360,"elapsed":20047,"user":{"displayName":"Alexis Prieto","userId":"17070250717485939340"}},"outputId":"8a304476-2e06-4111-c084-e1aab47997f6"},"source":["import pandas as pd\n","import numpy as np\n","import torch\n","from torch.utils.data import DataLoader, Dataset\n","from transformers import BertForSequenceClassification, BertTokenizer\n","import warnings\n","warnings.filterwarnings('ignore')\n","\n","print(\"=\"*70)\n","print(\"PHASE 4: FULL INFERENCE ON ALL SENTENCES (Updated with Apple Health)\")\n","print(\"=\"*70)\n","\n","# Label mapping\n","id_to_label = {\n","    0: 'Data Collection',\n","    1: 'Data Sharing/Third Parties',\n","    2: 'Data Retention',\n","    3: 'User Rights',\n","    4: 'Security/Encryption',\n","    5: 'Cookies/Tracking',\n","    6: 'Children/Minors',\n","    7: 'Policy Updates',\n","    8: 'General/Non-Privacy'\n","}\n","\n","# STEP 1: Use the already combined df_all\n","print(\"\\nSTEP 1: Using the combined dataset (df_all)\")\n","print(\"-\" * 70)\n","\n","# Re-initialize necessary variables if notebook state was reset or cleaned too aggressively\n","base_path = '/content/drive/MyDrive/femtech-bert-project'\n","data_path = f'{base_path}/data'\n","models_path = f'{base_path}/models'\n","\n","# Load original all_sentences.csv\n","df_all_original = pd.read_csv(f'{data_path}/all_sentences.csv')\n","\n","# Re-load df_apple_health (or assume it's created earlier)\n","# For robust execution in cleaned notebook, explicitly define or load df_apple_health\n","import nltk\n","from nltk.tokenize import sent_tokenize\n","try:\n","    nltk.data.find('tokenizers/punkt')\n","except LookupError:\n","    nltk.download('punkt')\n","try:\n","    nltk.data.find('tokenizers/punkt_tab')\n","except LookupError:\n","    nltk.download('punkt_tab')\n","\n","try:\n","    with open('apple_health_policy.txt', 'r') as f:\n","        text_content_apple_health = f.read()\n","    sentences_apple_health = sent_tokenize(text_content_apple_health)\n","    df_apple_health = pd.DataFrame({\n","        'sentence': sentences_apple_health,\n","        'app': 'apple_health'\n","    })\n","except FileNotFoundError:\n","    print(\"Warning: 'apple_health_policy.txt' not found. Apple Health data will not be included.\")\n","    df_apple_health = pd.DataFrame(columns=['sentence', 'app'])\n","except Exception as e:\n","    print(f\"Error recreating df_apple_health: {e}. Apple Health data will not be included.\")\n","    df_apple_health = pd.DataFrame(columns=['sentence', 'app'])\n","\n","\n","df_all = pd.concat([df_all_original, df_apple_health], ignore_index=True)\n","\n","print(f\"Loaded {len(df_all)} sentences\")\n","print(f\"Apps: {df_all['app'].unique().tolist()}\")\n","print(f\"App distribution:\")\n","print(df_all['app'].value_counts())\n","\n","# STEP 2: Load trained model\n","print(\"\\nSTEP 2: Loading trained BERT model\")\n","print(\"-\" * 70)\n","\n","device = torch.device('cuda' if torch.cuda.is_available() else 'cpu')\n","print(f\"Using device: {device}\")\n","\n","# Corrected: Load model and tokenizer from the models_path\n","model_load_path = f'{models_path}/bert_privacy_classifier'\n","model = BertForSequenceClassification.from_pretrained(model_load_path)\n","tokenizer = BertTokenizer.from_pretrained(model_load_path)\n","model.to(device)\n","model.eval()\n","\n","print(\"Model loaded successfully\")\n","\n","# STEP 3: Create inference dataset\n","print(\"\\nSTEP 3: Preparing for inference\")\n","print(\"-\" * 70)\n","\n","class InferenceDataset(Dataset):\n","    def __init__(self, texts, tokenizer, max_length=256):\n","        self.encodings = tokenizer(\n","            texts.tolist(), # Convert numpy array to list\n","            truncation=True,\n","            padding=True,\n","            max_length=max_length,\n","            return_tensors='pt'\n","        )\n","\n","    def __len__(self):\n","        return len(self.encodings['input_ids'])\n","\n","    def __getitem__(self, idx):\n","        return {\n","            'input_ids': self.encodings['input_ids'][idx],\n","            'attention_mask': self.encodings['attention_mask'][idx]\n","        }\n","\n","inference_dataset = InferenceDataset(df_all['sentence'].values, tokenizer)\n","inference_loader = DataLoader(inference_dataset, batch_size=16, shuffle=False)\n","\n","print(f\"Inference dataset: {len(inference_dataset)} sentences\")\n","print(f\"Batch size: 16\")\n","\n","# STEP 4: Run inference\n","print(\"\\nSTEP 4: Running inference\")\n","print(\"-\" * 70)\n","\n","all_preds = []\n","all_probs = []\n","all_confidences = []\n","\n","with torch.no_grad():\n","    for batch_idx, batch in enumerate(inference_loader):\n","        if (batch_idx + 1) % 20 == 0:\n","            print(f\"  Processed: {min((batch_idx + 1) * 16, len(inference_dataset))}/{len(inference_dataset)}\")\n","\n","        input_ids = batch['input_ids'].to(device)\n","        attention_mask = batch['attention_mask'].to(device)\n","\n","        outputs = model(input_ids=input_ids, attention_mask=attention_mask)\n","        logits = outputs.logits\n","        probs = torch.softmax(logits, dim=1)\n","        preds = torch.argmax(logits, dim=1)\n","        confidences = torch.max(probs, dim=1)[0]\n","\n","        all_preds.extend(preds.cpu().numpy())\n","        all_probs.extend(probs.cpu().numpy())\n","        all_confidences.extend(confidences.cpu().numpy())\n","\n","print(f\"Inference complete: {len(all_preds)} predictions\")\n","\n","# STEP 5: Create results dataframe\n","print(\"\\nSTEP 5: Creating results\")\n","print(\"-\" * 70)\n","\n","results_df = df_all.copy()\n","results_df['predicted_label'] = [id_to_label[p] for p in all_preds]\n","results_df['predicted_label_code'] = np.array(all_preds) + 1\n","results_df['confidence'] = all_confidences\n","\n","# Add top-3 predictions\n","for i in range(3):\n","    col_name = f'prediction_{i+1}_label'\n","    conf_name = f'prediction_{i+1}_confidence'\n","\n","    top_k_indices = np.argsort(-np.array(all_probs), axis=1)[:, i]\n","    results_df[col_name] = [id_to_label[idx] for idx in top_k_indices]\n","    results_df[conf_name] = [all_probs[j][top_k_indices[j]] for j in range(len(top_k_indices))]\n","\n","print(f\"Results dataframe created: {len(results_df)} rows\")\n","print(f\"Columns: {results_df.columns.tolist()}\")\n","\n","# STEP 6: Generate statistics\n","print(\"\\nSTEP 6: Generating statistics\")\n","print(\"-\" * 70)\n","\n","print(\"\\nPredicted label distribution (all sentences):\")\n","print(results_df['predicted_label'].value_counts())\n","\n","print(\"\\nConfidence distribution:\")\n","print(f\"  Min:    {results_df['confidence'].min():.4f}\")\n","print(f\"  Max:    {results_df['confidence'].max():.4f}\")\n","print(f\"  Mean:   {results_df['confidence'].mean():.4f}\")\n","print(f\"  Median: {results_df['confidence'].median():.4f}\")\n","\n","high_conf_count = (results_df['confidence'] >= 0.7).sum()\n","print(f\"\\nHigh confidence predictions (>= 0.7): {high_conf_count} ({high_conf_count/len(results_df)*100:.1f}%)\")\n","\n","# STEP 7: Privacy risk analysis by app\n","print(\"\\nSTEP 7: Privacy risk analysis by app\")\n","print(\"-\" * 70)\n","\n","privacy_risk_categories = [\n","    'Data Collection',\n","    'Data Sharing/Third Parties',\n","    'Cookies/Tracking',\n","    'Data Retention'\n","]\n","\n","app_analysis = []\n","\n","for app in sorted(results_df['app'].unique()):\n","    app_data = results_df[results_df['app'] == app]\n","\n","    total_sentences = len(app_data)\n","\n","    privacy_risk_count = app_data[app_data['predicted_label'].isin(privacy_risk_categories)].shape[0]\n","    privacy_risk_pct = privacy_risk_count / total_sentences * 100\n","\n","    avg_confidence = app_data['confidence'].mean()\n","\n","    label_dist = app_data['predicted_label'].value_counts()\n","\n","    app_analysis.append({\n","        'app': app,\n","        'total_sentences': total_sentences,\n","        'privacy_risk_sentences': privacy_risk_count,\n","        'privacy_risk_percentage': privacy_risk_pct,\n","        'avg_confidence': avg_confidence,\n","        'data_collection': label_dist.get('Data Collection', 0),\n","        'data_sharing': label_dist.get('Data Sharing/Third Parties', 0),\n","        'cookies_tracking': label_dist.get('Cookies/Tracking', 0),\n","        'data_retention': label_dist.get('Data Retention', 0),\n","        'user_rights': label_dist.get('User Rights', 0),\n","    })\n","\n","app_summary_df = pd.DataFrame(app_analysis)\n","app_summary_df = app_summary_df.sort_values('privacy_risk_percentage', ascending=False)\n","\n","print(\"\\nApp Privacy Risk Ranking:\")\n","print(app_summary_df[['app', 'total_sentences', 'privacy_risk_sentences', 'privacy_risk_percentage', 'avg_confidence']].to_string(index=False))\n","\n","# STEP 8: Save results\n","print(\"\\nSTEP 8: Saving results\")\n","print(\"-\" * 70)\n","\n","results_df.to_csv('bert_full_predictions_updated.csv', index=False)\n","print(\"Saved: bert_full_predictions_updated.csv\")\n","\n","app_summary_df.to_csv('privacy_risk_by_app_updated.csv', index=False)\n","print(\"Saved: privacy_risk_by_app_updated.csv\")\n","\n","# Category distribution\n","category_dist = results_df['predicted_label'].value_counts().to_frame('count')\n","category_dist['percentage'] = (category_dist['count'] / len(results_df) * 100).round(2)\n","category_dist.to_csv('privacy_category_distribution_updated.csv')\n","print(\"Saved: privacy_category_distribution_updated.csv\")\n","\n","# STEP 9: Generate summary report\n","print(\"\\nSTEP 9: Generating summary report\")\n","print(\"-\" * 70)\n","\n","summary_text = f\"\"\"\n","BERT FULL INFERENCE SUMMARY (Updated with Apple Health)\n","{'='*70}\n","\n","Dataset Overview:\n","  Total sentences analyzed: {len(results_df):,}\n","  Unique apps: {results_df['app'].nunique()}\n","  Average confidence: {results_df['confidence'].mean():.4f}\n","\n","Privacy Category Distribution:\n","\"\"\"\n","\n","for label, count in results_df['predicted_label'].value_counts().items():\n","    pct = count / len(results_df) * 100\n","    summary_text += f\"  {label:30s}: {count:4d} ({pct:5.1f}%)\\n\"\n","\n","summary_text += f\"\"\"\n","\n","Privacy Risk Assessment:\n","  Privacy-concerning categories: Data Collection, Data Sharing/Third Parties,\n","                                  Cookies/Tracking, Data Retention\n","\n","  Apps by privacy risk (% of sentences in risk categories):\n","\"\"\"\n","\n","for idx, row in app_summary_df.head(7).iterrows():\n","    summary_text += f\"  {row['app']:20s}: {row['privacy_risk_percentage']:5.1f}% ({row['privacy_risk_sentences']}/{row['total_sentences']} sentences)\\n\"\n","\n","summary_text += f\"\"\"\n","\n","Confidence Analysis:\n","  High confidence (>= 0.7): {high_conf_count:4d} ({high_conf_count/len(results_df)*100:5.1f}%)\n","  Min confidence: {results_df['confidence'].min():.4f}\n","  Max confidence: {results_df['confidence'].max():.4f}\n","\n","Key Findings:\n","  1. Most common privacy categories: {results_df['predicte