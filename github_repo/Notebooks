csv\")\n","\n","# Category distribution\n","category_dist = results_df['predicted_label'].value_counts().to_frame('count')\n","category_dist['percentage'] = (category_dist['count'] / len(results_df) * 100).round(2)\n","category_dist.to_csv('privacy_category_distribution_updated.csv')\n","print(\"Saved: privacy_category_distribution_updated.csv\")\n","\n","# STEP 9: Generate summary report\n","print(\"\\nSTEP 9: Generating summary report\")\n","print(\"-\" * 70)\n","\n","summary_text = f\"\"\"\n","BERT FULL INFERENCE SUMMARY (Updated with Apple Health)\n","{'='*70}\n","\n","Dataset Overview:\n","  Total sentences analyzed: {len(results_df):,}\n","  Unique apps: {results_df['app'].nunique()}\n","  Average confidence: {results_df['confidence'].mean():.4f}\n","\n","Privacy Category Distribution:\n","\"\"\"\n","\n","for label, count in results_df['predicted_label'].value_counts().items():\n","    pct = count / len(results_df) * 100\n","    summary_text += f\"  {label:30s}: {count:4d} ({pct:5.1f}%)\\n\"\n","\n","summary_text += f\"\"\"\n","\n","Privacy Risk Assessment:\n","  Privacy-concerning categories: Data Collection, Data Sharing/Third Parties,\n","                                  Cookies/Tracking, Data Retention\n","\n","  Apps by privacy risk (% of sentences in risk categories):\n","\"\"\"\n","\n","for idx, row in app_summary_df.head(7).iterrows():\n","    summary_text += f\"  {row['app']:20s}: {row['privacy_risk_percentage']:5.1f}% ({row['privacy_risk_sentences']}/{row['total_sentences']} sentences)\\n\"\n","\n","summary_text += f\"\"\"\n","\n","Confidence Analysis:\n","  High confidence (>= 0.7): {high_conf_count:4d} ({high_conf_count/len(results_df)*100:5.1f}%)\n","  Min confidence: {results_df['confidence'].min():.4f}\n","  Max confidence: {results_df['confidence'].max():.4f}\n","\n","Key Findings:\n","  1. Most common privacy categories: {results_df['predicted_label'].value_counts().index[0]}, {results_df['predicted_label'].value_counts().index[1]}\n","  2. H