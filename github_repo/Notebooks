as np\n","import torch\n","from torch.utils.data import DataLoader, Dataset\n","from transformers import BertForSequenceClassification, BertTokenizer\n","import warnings\n","import re\n","import os\n","warnings.filterwarnings('ignore')\n","\n","print(\"=\"*70)\n","print(\"RE-INITIALIZING DATA AND RE-RUNNING FULL INFERENCE\")\n","print(\"=\"*70)\n","\n","# Explicitly define paths to ensure they are in scope\n","base_path = '/content/drive/MyDrive/femtech-bert-project'\n","data_path = f'{base_path}/data'\n","models_path = f'{base_path}/models'\n","\n","# --- Step 1: Re-create df_all --- #\n","\n","# Load original all_sentences.csv\n","df_all_original = pd.read_csv(f'{data_path}/all_sentences.csv')\n","\n","# Re-load df_apple_health\n","# This assumes 'apple_health_policy.txt' was successfully uploaded and is accessible.\n","# For robustness, we re-tokenize it here if needed, or assume df_apple_health is in scope.\n","\n","# Check if df_apple_health exists in current session, if not, try to recreate from file\n","if 'df_apple_health' not in locals() and 'df_apple_health' not in globals():\n","    print(\"\\nRecreating df_apple_health from 'apple_health_policy.txt'...\")\n","    try:\n","        import nltk\n","        from nltk.tokenize import sent_tokenize\n","        try:\n","            nltk.data.find('tokenizers/punkt')\n","        except LookupError:\n","            nltk.download('punkt')\n","        try:\n","            nltk.data.find('tokenizers/punkt_tab')\n","        except LookupError:\n","            nltk.download('punkt_tab')\n","\n","        apple_health_file_path = f'{data_path}/privacy_policies/apple_health_policy.txt'\n","        with open(apple_health_file_path, 'r') as f:\n","            text_content_apple_health = f.read()\n","        sentences_apple_health = sent_tokenize(text_content_apple_health)\n","        df_apple_health = pd.DataFrame({\n","            'sentence': sentences_apple_health,\n","            'app': 'apple_health'\n","        })\n","        print(f\"  Successfully recreated {len(df_apple_health)} sentences for Apple Health.\")\n","    except FileNotFoundError:\n","        print(\"  Warning: 'apple_health_policy.txt' not found. Apple Health data will not be included.\")\n","        df_apple_health = pd.DataFrame(columns=['sentence', 'app']) # Create empty df\n","    except Exception as e:\n","        print(f\"  Error recreating df_apple_health: {e}. Apple Health data will not be included.\")\n","        df_apple_health = pd.DataFrame(columns=['sentence', 'app'])\n","\n","# Combine the dataframes to form the complete df_all for this execution\n","df_all = pd.concat([df_all_original, df_apple_health], ignore_index=True)\n","\n","print(f\"\\nCombined df_all created with {len(df_all)} sentences.\")\n","print(f\"Apps in df_all: {df_all['app'].unique().tolist()}\")\n","\n","# --- Start Full Inference Logic (from 0a62b357) --- #\n","\n","print(\"\\n\" + \"=\"*70)\n","print(\"PHASE 4: FULL INFERENCE ON ALL SENTENCES (Updated with Apple Health)\")\n","print(\"=\"*70)\n","\n","# Label mapping\n","id_to_label = {\n","    0: 'Data Collection',\n","    1: 'Data Sharing/Third Parties',\n","    2: 'Data Retention',\n","    3: 'User Rights',\n","    4: 'Security/Encryption',\n","    5: 'Cookies/Tracking',\n","    6: 'Children/Minors',\n","    7: 'Policy Updates',\n","    8: 'General/Non-Privacy'\n","}\n","\n","# STEP 1: Using the combined dataset (df_all)\n","print(\"\\nSTEP 1: Using the combined dataset (df_all)\")\n","print(\"-\" * 70)\n","\n","print(f\"Loaded {len(df_all)} sentences\")\n","print(f\"Apps: {df_all['app'].unique().tolist()}\")\n","print(f\"App distribution:\")\n","print(df_all['app'].value_counts())\n","\n","# STEP 2: Load trained model\n","print(\"\\nSTEP 2: Loading trained BERT model\")\n","print(\"-\" * 70)\n","\n","device = torch.device('cuda' if torch.cuda.is_available() else 'cpu')\n","print(f\"Using device: {device}\")\n","\n","# Load model and tokenizer from the models_path\n","model_load_path = f'{models_path}/bert_privacy_classifier'\n","model = BertForSequenceClassification.from_pretrained(model_load_path)\n","tokenizer = BertTokenizer.from_pretrained(model_load_path)\n","model.to(device)\n","model.eval()\n","\n","print(\"Model loaded successfully\")\n","\n","# STEP 3: Create inference dataset\n","print(\"\\nSTEP 3: Preparing for inference\")\n","print(\"-\" * 70)\n","\n","class InferenceDataset(Dataset):\n","    def __init__(self, texts, tokenizer, max_length=256):\n","        self.encodings = tokenizer(\n","            texts.tolist(), # Convert numpy array to list\n","            truncation=True,\n","            padding=True,\n","            max_length=max_length,\n","            return_tensors='pt'\n","        )\n","\n","    def __len__(self):\n","        return len(self.encodings['input_ids'])\n","\n","    def __getitem__(self, idx):\n","        return {\n","            'input_ids': self.encodings['input_ids'][idx],\n","            'attention_mask': self.encodings['attention_mask'][idx]\n","        }\n","\n","inference_dataset = InferenceDataset(df_all['sentence'].values, tokenizer)\n","inference_loader = DataLoader(inference_dataset, batch_size=16, shuffle=False)\n","\n","print(f\"Inference dataset: {len(inference_dataset)} sentences\")\n","print(f\"Batch size: 16\")\n","\n","# STEP 4: Run inference\n","print(\"\\nSTEP 4: Running inference\")\n","print(\"-\" * 70)\n","\n","all_preds = []\n","all_probs = []\n","all_confidences = []\n","\n","with torch.no_grad():\n","    for batch_idx, batch in enumerate(inference_loader):\n","        if (batch_idx + 1) % 20 == 0:\n","            print(f\"  Processed: {min((batch_idx + 1) * 16, len(inference_dataset))}/{len(inference_dataset)}\")\n","\n","        input_ids = batch['input_ids'].to(device)\n","        attention_mask = batch['attention_mask'].to(device)\n","\n","        outputs = model(input_ids=input_ids, attention_mask=attention_mask)\n","        logits = outputs.logits\n","        probs = t