01b[0m\u001b[0mencoding\u001b[0m \u001b[0;32mand\u001b[0m \u001b[0;34m\"b\"\u001b[0m \u001b[0;32mnot\u001b[0m \u001b[0;32min\u001b[0m \u001b[0mioargs\u001b[0m\u001b[0;34m.\u001b[0m\u001b[0mmode\u001b[0m\u001b[0;34m:\u001b[0m\u001b[0;34m\u001b[0m\u001b[0;34m\u001b[0m\u001b[0m\n\u001b[1;32m    872\u001b[0m             \u001b[0;31m# Encoding\u001b[0m\u001b[0;34m\u001b[0m\u001b[0;34m\u001b[0m\u001b[0m\n\u001b[0;32m--> 873\u001b[0;31m             handle = open(\n\u001b[0m\u001b[1;32m    874\u001b[0m                 \u001b[0mhandle\u001b[0m\u001b[0;34m,\u001b[0m\u001b[0;34m\u001b[0m\u001b[0;34m\u001b[0m\u001b[0m\n\u001b[1;32m    875\u001b[0m                 \u001b[0mioargs\u001b[0m\u001b[0;34m.\u001b[0m\u001b[0mmode\u001b[0m\u001b[0;34m,\u001b[0m\u001b[0;34m\u001b[0m\u001b[0;34m\u001b[0m\u001b[0m\n","\u001b[0;31mFileNotFoundError\u001b[0m: [Errno 2] No such file or directory: '/content/drive/My Drive/femtech_final/violations_policy_pairs.csv'"]}]},{"cell_type":"code","source":["# Cell 4: Integrated Risk Scoring System\n","import pandas as pd\n","import numpy as np\n","\n","def calculate_risk_score(app_name, nli_results, bert_results=None, violations_count=None):\n","    \"\"\"\n","    Calculate integrated privacy risk score (0-100)\n","\n","    Components:\n","    - NLI contradiction score (40% weight)\n","    - Number of documented violations (30% weight)\n","    - Violation severity distribution (20% weight)\n","    - Data sharing category prevalence (10% weight)\n","    \"\"\"\n","\n","    app_nli = nli_results[nli_results['app_name'] == app_name]\n","\n","    # Component 1: Average NLI contradiction score (0-1 -> 0-40)\n","    avg_contradiction = app_nli['contradiction_score'].mean()\n","    nli_component = avg_contradiction * 40\n","\n","    # Component 2: Violation count normalized (0-30)\n","    # Assuming max violations across apps is ~10\n","    violation_count = len(app_nli)\n","    violation_component = min(violation_count / 10, 1) * 30\n","\n","    # Component 3: Severity distribution (0-20)\n","    severity_weights = {'CRITICAL': 1.0, 'HIGH': 0.7, 'MEDIUM': 0.4, 'LOW': 0.1}\n","    severity_scores = app_nli['severity'].map(severity_weights)\n","    severity_component = severity_scores.mean() * 20\n","\n","    # Component 4: High-risk violation types (0-10)\n","    high_risk_types = ['Data Sharing', 'Employer Sharing', 'Facebook SDK', 'Location']\n","    high_risk_count = app_nli[app_nli['violation_type'].isin(high_risk_types)].shape[0]\n","    type_component = min(high_risk_count / 5, 1) * 10\n","\n","    total_score = nli_component + violation_component + severity_component + type_component\n","\n","    return {\n","        'app_name': app_name,\n","        'risk_score': round(total_score, 1),\n","        'nli_component': round(nli_component, 1),\n","        'violation_component': round(violation_component, 1),\n","        'severity_component': round(severity_component, 1),\n","        'type_component': round(type_component, 1),\n","        'avg_contradiction': round(avg_contradiction, 3),\n","        'violation_count': violation_count,\n","        'risk_level': 'CRITICAL' if total_score >= 70 else 'HIGH' if total_score >= 50 else 'MEDIUM' if total_score >= 30 else 'LOW'\n","    }\n","\n","# Calculate for all apps\n","nli_results_df = pd.read_csv('/content/drive/My Drive/femtech_final/results/nli_contradiction_results.csv')\n","apps = nli_results_df['app_name'].unique()\n","\n","risk_scores = []\n","for app in apps:\n","    score = calculate_risk_score(app, nli_results_df)\n","    risk_scores.append(score)\n","    print(f\"{app}: {score['risk_score']}/100 ({score['risk_level']})\")\n","\n","risk_df = pd.DataFrame(risk_scores)\n","risk_df = risk_df.sort_values('risk_score', ascending=False)\n","risk_df.to_csv('/content/drive/My Drive/femtech_final/results/integrated_risk_scores.csv', index=False)\n","\n","print(\"\\n\" + \"=\"*60)\n","print(\"INTEGRATED PRIVACY RISK RANKINGS\")\n","print(\"=\"*60)\n","print(risk_df[['app_name', 'risk_score', 'risk_level', 'violation_count']].to_string(index=False))"],"metadata":{"id":"-X58dyqpXZn_"},"execution_count":null,"outputs":[]}]}
