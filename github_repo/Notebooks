icted_label'].value_counts().index[1]}\n","  2. Highest privacy risk app: {app_summary_df.iloc[0]['app']} ({app_summary_df.iloc[0]['privacy_risk_percentage']:.1f}%)\n","  3. Model confidence: Average {results_df['confidence'].mean():.1%}\n","\n","Files Generated:\n","  - bert_full_predictions_updated.csv: All sentences with predictions\n","  - privacy_risk_by_app_updated.csv: Summary statistics per app\n","  - privacy_category_distribution_updated.csv: Category breakdown\n","  - inference_summary_updated.txt: Summary report\n","\"\"\"\n","\n","with open('inference_summary_updated.txt', 'w') as f:\n","    f.write(summary_text)\n","\n","print(summary_text)\n","print(\"\\nSaved: inference_summary_updated.txt\")\n","\n","print(\"\\n\" + \"=\"*70)\n","print(\"PHASE 4 COMPLETE (Updated)\")\n","print(\"=\"*70)\n","print(\"\\nFiles ready for download:\")\n","print(\"  1. bert_full_predictions_updated.csv - All predictions\")\n","print(\"  2. privacy_risk_by_app_updated.csv - Risk analysis by app\")\n","print(\"  3. privacy_category_distribution_updated.csv - Category breakdown\")\n","print(\"  4. inference_summary_updated.txt - Summary report\")"],"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["======================================================================\n","RE-INITIALIZING DATA AND RE-RUNNING FULL INFERENCE\n","======================================================================\n","\n","Combined df_all created with 1629 sentences.\n","Apps in df_all: ['flo', 'clue', 'glow', 'ovia', 'maya', 'apple_health']\n","\n","======================================================================\n","PHASE 4: FULL INFERENCE ON ALL SENTENCES (Updated with Apple Health)\n","======================================================================\n","\n","STEP 1: Using the combined dataset (df_all)\n","----------------------------------------------------------------------\n","Loaded 1629 sentences\n","Apps: ['flo', 'clue', 'glow', 'ovia', 'may