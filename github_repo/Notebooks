otected', 'claim_type': 'False Security Claim', 'actual_practice': 'User fertility and pregnancy data accessible to anyone with the user email address', 'label': 1, 'source': 'California Attorney General Settlement 2020', 'severity': 'Critical'},\n","        {'app_name': 'Glow', 'violation_date': '2020', 'violation_type': 'Security Standards', 'policy_sentence': 'We implement industry-standard security measures', 'claim_type': 'Vague Security Claim', 'actual_practice': 'Failed to implement basic authentication controls, allowing unauthorized profile access', 'label': 1, 'source': 'California Attorney General Settlement 2020', 'severity': 'High'},\n","        {'app_name': 'Glow', 'violation_date': '2020', 'violation_type': 'Encryption Claims', 'policy_sentence': 'We use encryption to protect your sensitive information', 'claim_type': 'Incomplete Security Disclosure', 'actual_practice': 'While data was encrypted in transit, access controls were so weak that encryption was effectively meaningless', 'label': 1, 'source': 'Consumer Reports 2020', 'severity': 'High'},\n","\n","        # MAYA violations\n","        {'app_name': 'Maya', 'violation_date': '2020', 'violation_type': 'Third-Party SDK', 'policy_sentence': 'We do not share your personal data with third parties for their marketing purposes', 'claim_type': 'Incomplete Disclosure', 'actual_practice': 'Shared user data with Facebook through embedded Facebook SDK for targeted advertising', 'label': 1, 'source': 'Privacy Activist Investigation 2020', 'severity': 'High'},\n","        {'app_name': 'Maya', 'violation_date': '2020', 'violation_type': 'SDK Removal After Pressure', 'policy_sentence': 'We are committed to protecting your privacy', 'claim_type': 'Reactive Rather Than Proactive', 'actual_practice': 'Only removed Facebook SDK after privacy activists publicly exposed the data sharing', 'label': 1, 'source': 'Privacy Activist Reports 2020', 'severity': 'Medium'},\n","\n","        # MIA FEM violation\n","        {'app_name': 'Mia Fem', 'violation_date': '2019', 'violation_type': 'Direct Third-Party Sharing', 'policy_sentence': 'Your health data is private and secure', 'claim_type': 'False Privacy Claim', 'actual_practice': 'Directly shared period tracking data with Facebook', 'label': 1, 'source': 'Privacy International Report 2019', 'severity': 'High'},\n","\n","        # PERIOD TRACKER violation\n","        {'app_name': 'Period Tracker', 'violation_date': '2020', 'violation_type': 'International Data Transfer', 'policy_sentence': 'Your data is protected with appropriate security measures', 'claim_type': 'Omission of International Transfer', 'actual_practice': 'Shared data with Chinese advertising companies without disclosure of international transfer', 'label': 1, 'source': 'Consumer Reports Investigation 2020', 'severity': 'High'},\n","\n","        # NON-VIOLATIONS\n","        {'app_name': 'Apple Health', 'violation_date': 'N/A', 'violation_type': 'None', 'policy_sentence': 'Health data is encrypted on your device and Apple cannot access it without your explicit permission', 'claim_type': 'Clear Technical Disclosure', 'actual_practice': 'No documented violations; encryption claims verified by security researchers', 'label': 0, 'source': 'Apple Privacy Policy - No violations documented', 'severity': 'N/A'},\n","        {'app_name': 'Apple Health', 'violation_date': 'N/A', 'violation_type': 'None', 'policy_sentence': 'When your phone is locked with a passcode, all of your health and fitness data in the Health app is encrypted', 'claim_type': 'Specific Technical Claim', 'actual_practice': 'Independently verified encryption implementation', 'label': 0, 'source': 'Apple Privacy Policy - Verified by security audit', 'severity': 'N/A'},\n","        {'app_name': 'Clue', 'violation_date': 'N/A', 'violation_type': 'None', 'policy_sentence': 'We will never sell your personal data for monetary gain', 'claim_type': 'Strong Commitment', 'actual_practice': 'No evidence of direct data sales (though data leaked through third parties)', 'label': 0, 'source': 'Clue Privacy Policy - No direct sales documented', 'severity': 'N/A'},\n","        {'app_name': 'Flo', 'violation_date': 'N/A', 'violation_type': 'None', 'policy_sentence': 'Anonymous Mode allows you to use Flo without your name, email, or technical identifiers', 'claim_type': 'Clear Feature Description', 'actual_practice': 'Anonymous Mode feature functions as described post-FTC settlement', 'label': 0, 'source': 'Flo Privacy Policy Post-2021 - Feature verified', 'severity': 'N/A'},\n","        {'app_name': 'Glow', 'violation_date': 'N/A', 'violation_type': 'None', 'policy_sentence': 'You can delete your account and all associated data at any time', 'claim_type': 'Clear User Right', 'actual_practice': 'Deletion functionality works as stated (post-2020 settlement)', 'label': 0, 'source': 'Glow Privacy Policy Post-Settlement', 'severity': 'N/A'},\n","    ]\n","\n","    expanded_df = pd.DataFrame(all_violations)\n","    expanded_df.to_csv('violation_evidence_expanded.csv', index=False)\n","    print(f\"Created violation_evidence_expanded.csv with {len(expanded_df)} cases\")\n","else:\n","    expanded_df = pd.read_csv('violation_evidence_expanded.csv')\n","    print(f\"Loaded existing violation dataset: {len(expanded_df)} cases\")\n","\n","print(f\"  Violations (label=1): {len(expanded_df[expanded_df['label']==1])}\")\n","print(f\"  Non-violations (label=0): {len(expanded_df[expanded_df['label']==0])}\")\n","\n","# Define discrepancy detection function\n","def detect_policy_practice_discrepancy(policy_claim, actual_practice, app_name):\n","    \"\"\"\n","    Detect discrepancies between policy claims and actual practices\n","    \"\"\"\n","    policy_lower = policy_claim.lower()\n","    practice_lower = actual_practice.lower()\n","\n","    discrepancy_score = 0\n","    reasons = []\n","\n","    # 1. Explicit denials contradicted by practice\n","    denials = ['do not share', 'will not share', 'never share', 'not sell', 'will not sell', 'does not sell']\n","    sharing_actions = ['shared', 'sharing', 'disclosed', 'sent to', 'provided to', 'transferred']\n","\n","    has_denial = any(denial in policy_lower for denial in denials)\n","    has_sharing = any(action in practice_lower for action in sharing_actions)\n","\n","    if has_denial and has_sharing:\n","        discrepancy_score += 5\n","        reasons.append(\"Explicit denial contradicted by actual sharing\")\n","\n","    # 2. Vague promises vs specific violations\n","    vague_promises = ['take seriously', 'committed to', 'protected', 'secure', 'private']\n","    specific_violations = ['facebook', 'google', 'third party', 'third-party', 'sdk', 'analytics', 'advertising']\n","\n","    has_vague = any(vague in policy_lower for vague in vague_promises)\n","    has_specific_violation = any(viol in practice_lower for viol in specific_violations)\n","\n","    if has_vague and has_specific_violation:\n","        discrepancy_score += 3\n","        reasons.append(\"Vague promise contradicted by specific sharing\")\n","\n","    # 3. Claims about control contradicted by unauthorized sharing\n","    control_claims = ['you control', 'you choose', 'you decide', 'your choice', 'you have control']\n","    unauthorized = ['without', 'unauthorized', 'no consent', 'without disclosure', 'without permission', 'not aware', 'buried']\n","\n","    has_control_claim = any(claim in policy_lower for claim in control_claims)\n","    is_unauthorized = any(unauth in practice_lower for unauth in unauthorized)\n","\n","    if has_control_claim and is_unauthorized:\n","        discrepancy_score += 4\n","        reasons.append(\"User control claims contradicted by unauthorized practice\")\n","\n","    # 4. Minimization claims contradicted by extensive collection\n","    minimization = ['minimal', 'only necessary', 'limited', 'necessary data', 'collect minimal']\n","    extensive = ['11 data points', 'extensive', 'multiple', '8+', 'numerous', 'beyond']\n","\n","    has_minimization = any(minim in policy_lower for minim in minimization)\n","    is_extensive = any(ext in practice_lower for ext in extensive)\n","\n","    if has_minimization and is_extensive:\n","        discrepancy_score += 3\n","        reasons.append(\"Data minimization claim contradicted by extensive collection\")\n","\n","    # 5. Security claims contradicted by breaches\n","    security_claims = ['securely stored', 'encrypted', 'protected', 'security measures', 'industry-standard']\n","    security_failures = ['accessible to anyone', 'breach', 'vulnerability', 'failed', 'weak', 'unauthorized access']\n","\n","    has_security_claim = any(sec in policy_lower for sec in security_claims)\n","    has_failure = any(fail in practice_lower for fail in security_failures)\n","\n","    if has_security_claim and has_failure:\n","        discrepancy_score += 4\n","        reasons.append(\"Security claims contradicted by actual failure\")\n","\n","    # 6. De-identification claims contradicted by re-identification\n","    deident_claims = ['de-identified', 'anonymized', 'aggregated', 'anonymous', 'cannot be linked']\n","    reident = ['re-identifiable', 'linked', 'linkable', 'identifiable through', 'context']\n","\n","    has_deident = any(de in policy_lower for de in deident_claims)\n","    is_reident = any(re in practice_lower for re in reident)\n","\n","    if has_deident and is_reident:\n","        discrepancy_score += 3\n","        reasons.append(\"De-identification claim contradicted by re-identification risk\")\n","\n","    # 7. Service provider euphemism with undisclosed third parties\n","    euphemisms = ['service provider', 'trusted partner', 'carefully selected', 'work with']\n","    undisclosed = ['without disclosing', 'embedded', 'hidden', 'not disclosed', 'specific third parties']\n","\n","    has_euphemism = any(euph in policy_lower for euph in euphemisms)\n","    is_undisclosed = any(und in practice_lower for und in undisclosed)\n","\n","    if has_euphemism and is_undisclosed:\n","        discrepancy_score += 3\n","        reasons.append(\"Vague third-party language with undisclosed sharing\")\n","\n","    # 8. Confidentiality claims contradicted\n","    confidential = ['confidential', 'remains confidential', 'private and secure']\n","    exposed = ['employer', 'shared with', 'leaked', 'available for purchase', 'marketplace']\n","\n","    has_confidential = any(conf in policy_lower for conf in confidential)\n","    is_exposed = any(exp in practice_lower for exp in exposed)\n","\n","    if has_confidential and is_exposed:\n","        discrepancy_score += 4\n","        reasons.append(\"Confidentiality claims contradicted by exposure\")\n","\n","    # Decision logic\n","    if discrepancy_score >= 5:\n","        return 1, 0.90, reasons[0] if reasons else \"High discrepancy score\"\n","    elif discrepancy_score >= 3:\n","        return 1, 0.75, reasons[0] if reasons else \"Moderate discrepancy\"\n","    elif discrepancy_score >= 1:\n","        return 1, 0.60, reasons[0] if reasons else \"Low discrepancy\"\n","    else:\n","        return 0, 0.50, \"No clear discrepancy detected\"\n","\n","# Run detection on all cases\n","print(\"\\nRunning discrepancy detection...\")\n","results = []\n","\n","for idx, row in expanded_df.iterrows():\n","    pred_label, confidence, reason = detect_policy_practice_discrepancy(\n","        row['policy_sentence'],\n","        row['actual_practice'],\n","        row['app_name']\n","    )\n","\n","    results.append({\n","        'app': row['app_name'],\n","        'violation_type': row['violation_type'],\n","        'policy_claim': row['policy_sentence'][:80] + '...',\n","        'actual_practice': row['actual_practice'][:80] + '...',\n","        'true_discrepancy': row['label'],\n","        'predicted_discrepancy': pred_label,\n","        'confidence': confidence,\n","        'detection_reason': reason,\n","        'correct': pred_label == row['label'],\n","        'severity': row['severity'],\n","        'source': row['source']\n","    })\n","\n","results_df = pd.DataFrame(results)\n","results_df.to_csv('policy_practice_discrepancy_results.csv', index=False)\n","\n","# Calculate metrics\n","accuracy = (results_df['correct'].sum() / len(results_df)) * 100\n","\n","print(\"\\n\" + \"=\"*60)\n","print(\"FINAL RESULTS\")\n","print(\"=\"*60)\n","print(f\"Total Cases: {len(results_df)}\")\n","print(f\"Overall Accuracy: {accuracy:.1f}%\")\n","print(f\"Correctly Detected: {results_df['correct'].sum()}/{len(results_df)}\")\n","\n","violations_only = results_df[results_df['true_discrepancy'] == 1]\n","detected = violations_only[violations_only['predicted_discrepancy'] == 1]\n","\n","print(f\"\\nViolation Detection (Sensitivity): {len(detected)}/{len(violations_only)} = {len(detected)/len(violations_only)*100:.1f}%\")\n","\n","non_violations = results_df[results_df['true_discrepancy'] == 0]\n","correct_non = non_violations[non_violations['predicted_discrepancy'] == 0]\n","\n","print(f\"Non-Violation Detection (Specificity): {len(correct_non)}/{len(non_violations)} = {len(correct_non)/len(non_violations)*100:.1f}%\")\n","\n","print(f\"\\n\" + \"=\"*60)\n","print(\"COMPARISON TO BASELINE\")\n","print(\"=\"*60)\n","print(f\"Baseline (BERT only):              22.2%\")\n","print(f\"Enhanced (Discrepancy Detection):  {accuracy:.1f}%\")\n","print(f\"Improvement:                       +{accuracy - 22.2:.1f} percentage points\")\n","\n","print(\"\\nResults saved to: policy_practice_discrepancy_results.csv\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"_oxZMN6StHjk","executionInfo":{"status":"ok","timestamp":1764130623536,"user_tz":360,"elapsed":1343,"user":{"displayName":"Alexis Prieto","userId":"17070250717485939340"}},"outputId":"efdfac96-73db-4aab-aee1-8fe2d59090b6"},"execution_count":4,"outputs":[{"output_type":"stream","name":"stdout","text":["============================================================\n","RUNNING E